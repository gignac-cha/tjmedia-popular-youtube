{
  "name": "tjmedia-popular-youtube-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:tjmedia-popular-worker": "pnpm --dir workers dev:tjmedia-popular",
    "dev:youtube-search-worker": "pnpm --dir workers dev:youtube-search",
    "dev:web": "pnpm --filter @tjmedia-popular-youtube/web dev",
    "storybook": "turbo run storybook --filter=@tjmedia-popular-youtube/web",
    "build-storybook": "turbo run build-storybook --filter=@tjmedia-popular-youtube/web"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  }
}
